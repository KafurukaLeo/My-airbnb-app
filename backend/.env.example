# Direct URL — used by Prisma CLI (migrate, reset, seed, studio)
# For Neon: remove -pooler from the hostname, remove channel_binding param
DATABASE_URL=

# Pooler URL — used by the app at runtime for connection pooling (optional)
# If omitted, the app falls back to DATABASE_URL
DATABASE_POOLER_URL=

JWT_SECRET=
JWT_EXPIRES_IN=7d

EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

API_URL=
PORT=3000
NODE_ENV=development

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

REDIS_URL=
GROQ_API_KEY=gsk_...